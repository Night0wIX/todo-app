{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "start:dev": "dotenvx run -f .env.development -- nest start --watch",
    "start:prod": "dotenvx run -f .env.production -- node dist/main.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/sequelize": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.1",
    "sequelize-typescript": "^2.1.6",
    "sqlite3": "5.1.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@dotenvx/dotenvx": "^1.67.0",
    "@nestjs/cli": "^11.0.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.40",
    "@types/node": "^24.0.0",
    "@types/sequelize": "^4.28.20",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": "22.x"
  }
}
